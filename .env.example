# Trading System API Keys — copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed to the repository.

# FRED — macro flags F (Fed) and I (Inflation). Free key, 30 sec to get:
#   https://fredaccount.stlouisfed.org/apikey
# Strongly recommended: the keyless fredgraph host (fred.stlouisfed.org) is
# blocked on some networks (yours times out), but the API host
# (api.stlouisfed.org) works and is used first when this key is set. Macro
# series are also disk-cached (data/silver/macro_cache/), so once fetched the
# flag board never hangs on a FRED outage.
FRED_API_KEY=your_fred_api_key_here
NEWSAPI_KEY=your_newsapi_key_here
# DeepSeek V4 — ts explain + AI narration  (https://platform.deepseek.com/api-keys)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Finnhub — symbol-tagged news + company-news sentiment (free 60 req/min)
#   https://finnhub.io/register   (Finnhub keys are NOT prefixed with pub_)
FINNHUB_API_KEY=your_finnhub_api_key_here
# NewsData.io — keyword news backend, free ~200 credits/day (keys look like pub_...)
#   https://newsdata.io/register
NEWSDATA_API_KEY=your_newsdata_api_key_here
